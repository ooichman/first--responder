# Copy this file to secret.env and fill in your values.
# This file is used by Kustomize secretGenerator to create the llm-credentials Secret.
#
# For local vLLM deployment:
#   api-base=http://vllm-service.first-responder.svc.cluster.local:8000/v1
#   model=Qwen/Qwen2.5-1.5B-Instruct
#   api-key=not-needed
#
# For OpenAI:
#   api-base=https://api.openai.com/v1
#   model=gpt-4o-mini
#   api-key=sk-your-key-here

api-base=http://vllm-service.first-responder.svc.cluster.local:8000/v1
model=Qwen/Qwen2.5-1.5B-Instruct
api-key=not-needed
